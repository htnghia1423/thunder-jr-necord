{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "src",
  "testRegex": ".*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "tsconfig.test.json"
      }
    ]
  },
  "collectCoverageFrom": ["**/*.(t|j)s", "!**/node_modules/**", "!**/dist/**", "!**/*.module.ts"],
  "coverageDirectory": "../coverage",
  "coverageReporters": ["text", "lcov", "clover"],
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/$1"
  }
}
